[Unit]
Description=Pipewire Connections
After=pipewire-filters.target
Requires=pipewire-filters.target
ConditionPathExists=/home/jack/connections.tab

[Service]
Type=oneshot
RemainAfterExit=true
WorkingDirectory=/home/jack
ExecStart=/bin/bash load-pipewire-connections.sh
ExecStop=/bin/bash load-pipewire-connections.sh -d
Restart=on-failure
RestartSec=1

[Install]
WantedBy=default.target
