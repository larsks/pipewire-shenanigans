[Unit]
Description=Load pipewire filter %i
After=pipewire-online.service
Requires=pipewire-online.service

[Service]
Type=exec
WorkingDirectory=/home/jack
Environment=WIREPLUMBER_DEBUG=2
ExecStart=/usr/bin/wpexec .config/wireplumber/filter.d/%i.lua
Restart=on-failure
RestartSec=1

[Install]
WantedBy=pipewire-filters.target
