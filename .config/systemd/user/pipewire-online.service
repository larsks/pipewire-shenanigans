[Unit]
Description=Pipewire online
After=pipewire.service wireplumber.service
Requires=pipewire.service wireplumber.service

[Service]
Type=oneshot
WorkingDirectory=/home/jack
ExecStart=/usr/bin/pw-cli info 0
StandardOutput=null
StandardError=inherit
Restart=on-failure
RestartSec=1

[Install]
WantedBy=default.target
