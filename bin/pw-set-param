#!/usr/bin/env python3
"""
pw-set-param - Set PipeWire node parameters by name.

Usage:
    pw-set-param <node-name> <param-name> <value>

Example:
    pw-set-param "echo-cancel-source" "nr:bypass" 0
    pw-set-param "alsa_output.pci.analog-stereo" "volume" 0.8
"""

import argparse
import json
import subprocess
import sys


def run_pw_dump():
    """Run pw-dump and return parsed JSON."""
    try:
        result = subprocess.run(["pw-dump"], capture_output=True, text=True, check=True)
        return json.loads(result.stdout)
    except FileNotFoundError:
        print("Error: pw-dump not found. Is PipeWire installed?", file=sys.stderr)
        sys.exit(1)
    except subprocess.CalledProcessError as e:
        print(f"Error running pw-dump: {e.stderr}", file=sys.stderr)
        sys.exit(1)
    except json.JSONDecodeError as e:
        print(f"Error parsing pw-dump output: {e}", file=sys.stderr)
        sys.exit(1)


def find_node(dump, node_name):
    """
    Find a node by name in the pw-dump output.
    Matches against node.name, node.nick, and node.description.
    Returns a list of matching nodes (id, info dict).
    """
    matches = []
    for entry in dump:
        if entry.get("type") not in ("PipeWire:Interface:Node",):
            continue
        info = entry.get("info", {})
        props = info.get("props", {})

        candidates = [
            str(props.get("node.name", "")),
            str(props.get("node.nick", "")),
            str(props.get("node.description", "")),
        ]
        if node_name in candidates or any(
            node_name.lower() in c.lower() for c in candidates if c
        ):
            matches.append((entry["id"], entry))

    return matches


# Direct Props properties (not in PropInfo, not in the params array).
# Maps name -> synthetic prop_info entry with constraints and is_param=False.
DIRECT_PROPS = {
    "volume": {
        "min": 0.0,
        "max": 10.0,
        "description": "Node volume",
        "is_param": False,
    },
}


def get_node_params(dump, node_id):
    """
    Find the current values of Props for a node from pw-dump output.
    Returns a dict of param_name -> {"current": value, "is_param": bool}

    Covers:
      - params array entries: alternating [name, value, ...] pairs (is_param=True)
      - known direct Props properties listed in DIRECT_PROPS (is_param=False)
    """
    params = {}

    for entry in dump:
        if entry.get("id") != node_id:
            continue
        info = entry.get("info", {})

        for param_block in info.get("params", {}).get("Props", []):
            # Known direct properties (e.g. volume)
            for key in DIRECT_PROPS:
                if key in param_block:
                    params[key] = {"current": param_block[key], "is_param": False}

            # Nested params array: flat [name, value, name, value, ...]
            raw_params = param_block.get("params", [])
            it = iter(raw_params)
            for name in it:
                try:
                    value = next(it)
                except StopIteration:
                    break
                params[name] = {"current": value, "is_param": True}

    return params


def get_prop_types(dump, node_id):
    """
    Extract the PropInfo (type, min, max, description) for each param from pw-dump.

    pw-dump represents PropInfo blocks like:
      {
        "name": "nr:bypass",
        "type": { "default": 0.0, "min": 0.0, "max": 1.0 },
        "params": true
      }
    or for enums:
      {
        "name": "nr:level",
        "type": { "default": 0, "values": [...], "labels": [...] },
        "params": true
      }
    The constraints live inside the "type" dict, not at the top level.
    """
    prop_info = {}

    for entry in dump:
        if entry.get("id") != node_id:
            continue
        info = entry.get("info", {})

        for block in info.get("params", {}).get("PropInfo", []):
            name = block.get("name", block.get("id"))
            if not name:
                continue

            # "type" is either a dict of constraints, or a plain string like "Float"
            type_field = block.get("type", {})
            type_constraints = type_field if isinstance(type_field, dict) else {}

            info_entry = {
                "description": block.get("description", ""),
                # Keep the raw type field for display purposes
                "type": type_field,
                # True  -> set via Props.params (e.g. nr:bypass)
                # False -> set as a direct Props property (e.g. volume)
                "is_param": block.get("params", False),
            }

            # Pull min/max/default out of the nested "type" dict
            for key in ("min", "max", "default"):
                if key in type_constraints:
                    info_entry[key] = type_constraints[key]

            # Enum support: values / labels also live inside "type"
            for key in ("values", "labels"):
                if key in type_constraints:
                    info_entry[key] = type_constraints[key]

            prop_info[name] = info_entry

    return prop_info


def coerce_value(raw_value, prop_info_entry):
    """
    Attempt to coerce raw_value (string from CLI) to the appropriate type,
    using prop_info_entry for guidance. Returns the coerced value.
    """
    ptype = prop_info_entry.get("type", "unknown") if prop_info_entry else "unknown"

    # Try float first for numeric types
    try:
        if "." in raw_value:
            return float(raw_value)
        else:
            int_val = int(raw_value)
            return int_val
    except ValueError:
        pass

    # Boolean strings
    if raw_value.lower() in ("true", "yes", "on"):
        return True
    if raw_value.lower() in ("false", "no", "off"):
        return False

    # Return as string
    return raw_value


def validate_value(value, prop_info_entry, param_name):
    """
    Validate value against min/max constraints.
    Returns (is_valid, error_message).
    """
    if not prop_info_entry:
        return True, None

    # Check numeric range
    if isinstance(value, (int, float)):
        if "min" in prop_info_entry and value < prop_info_entry["min"]:
            return False, (
                f"Value {value} is below minimum {prop_info_entry['min']} "
                f"for parameter '{param_name}'"
            )
        if "max" in prop_info_entry and value > prop_info_entry["max"]:
            return False, (
                f"Value {value} is above maximum {prop_info_entry['max']} "
                f"for parameter '{param_name}'"
            )

    # Check enum values
    if "values" in prop_info_entry:
        allowed = prop_info_entry["values"]
        if value not in allowed:
            labels = prop_info_entry.get("labels", allowed)
            choices = ", ".join(f"{v} ({l})" for v, l in zip(allowed, labels))
            return False, (
                f"Value {value!r} is not valid for '{param_name}'. "
                f"Allowed values: {choices}"
            )

    return True, None


def set_param(node_id, param_name, value, is_param=True):
    """Run pw-cli set-param for the given node id, param name, and value.

    is_param=True  -> Props { params: ["name", value] }  (e.g. nr:bypass)
    is_param=False -> Props { name: value }               (e.g. volume)
    """
    # Format the value appropriately for the Props SPA pod syntax
    if isinstance(value, bool):
        formatted = "true" if value else "false"
    elif isinstance(value, float):
        formatted = repr(value)
    elif isinstance(value, int):
        formatted = str(value)
    else:
        formatted = f'"{value}"'

    if is_param:
        props_arg = f'{{ params: [ "{param_name}", {formatted}] }}'
    else:
        props_arg = f"{{ {param_name}: {formatted} }}"
    cmd = ["pw-cli", "set-param", str(node_id), "Props", props_arg]

    print(f"Running: {' '.join(cmd)}")

    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        if result.stdout.strip():
            print(result.stdout.strip())
        return True
    except subprocess.CalledProcessError as e:
        print(
            f"Error: pw-cli failed: {e.stderr.strip() or e.stdout.strip()}",
            file=sys.stderr,
        )
        return False


def print_node_params(node_id, current_params, prop_types):
    """Pretty-print available parameters for a node."""
    print(f"\nAvailable parameters for node {node_id}:")
    all_names = sorted(set(list(current_params.keys()) + list(prop_types.keys())))
    if not all_names:
        print("  (no Props parameters found)")
        return
    for name in all_names:
        info = prop_types.get(name, {})
        current = current_params.get(name, {}).get("current", "?")
        desc = info.get("description", "")
        constraints = []
        if "min" in info:
            constraints.append(f"min={info['min']}")
        if "max" in info:
            constraints.append(f"max={info['max']}")
        if "default" in info:
            constraints.append(f"default={info['default']}")
        if "values" in info:
            labels = info.get("labels", info["values"])
            choices = "/".join(str(l) for l in labels)
            constraints.append(f"choices={choices}")
        # Show the type name if it's a plain string (e.g. "Float", "Int", "Bool")
        type_field = info.get("type", "")
        if isinstance(type_field, str) and type_field:
            constraints.append(f"type={type_field}")
        constraint_str = f"  [{', '.join(constraints)}]" if constraints else ""
        desc_str = f"  # {desc}" if desc else ""
        print(f"  {name}: {current}{constraint_str}{desc_str}")


def list_nodes(dump):
    """Print all available PipeWire node names."""
    nodes = []
    for entry in dump:
        if entry.get("type") != "PipeWire:Interface:Node":
            continue
        props = entry.get("info", {}).get("props", {})
        name = props.get("node.name", "")
        nick = props.get("node.nick", "")
        desc = props.get("node.description", "")
        nodes.append((entry["id"], name, nick, desc))

    nodes.sort(key=lambda x: x[1].lower())
    print(f"{'ID':>6}  {'node.name':<45}  {'description'}")
    print(f"{'------':>6}  {'-' * 45}  {'-' * 30}")
    for node_id, name, nick, desc in nodes:
        extra = (
            desc if desc and desc != name else (nick if nick and nick != name else "")
        )
        print(f"{node_id:>6}  {name:<45}  {extra}")


def main():
    parser = argparse.ArgumentParser(
        description="Set PipeWire node parameters by name.",
        epilog="Example: pw-set-param 'echo-cancel-source' 'nr:bypass' 0",
    )
    parser.add_argument(
        "node_name", nargs="?", help="Node name (or substring) to target"
    )
    parser.add_argument("param_name", nargs="?", help="Parameter name to set")
    parser.add_argument("value", nargs="?", help="Value to set")
    parser.add_argument(
        "--list",
        "-l",
        action="store_true",
        help="List available parameters for the node and exit",
    )
    parser.add_argument(
        "--list-nodes",
        "-L",
        action="store_true",
        help="List all available node names and exit",
    )
    parser.add_argument(
        "--exact",
        "-e",
        action="store_true",
        help="Require exact node name match (no substring matching)",
    )

    args = parser.parse_args()

    # --list-nodes needs no node_name; handle it before other validation
    if args.list_nodes:
        dump = run_pw_dump()
        list_nodes(dump)
        sys.exit(0)

    # Validate args
    if not args.node_name:
        parser.error(
            "node_name is required (or use --list-nodes to see available nodes)"
        )
    if not args.list and (args.param_name is None or args.value is None):
        parser.error("param_name and value are required unless --list is used")

    # Load pw-dump
    print("Querying PipeWire...", file=sys.stderr)
    dump = run_pw_dump()

    # Find node(s)
    matches = find_node(dump, args.node_name)

    if args.exact:
        # Re-filter for exact matches only
        exact = []
        for node_id, entry in matches:
            props = entry.get("info", {}).get("props", {})
            names = [
                props.get("node.name", ""),
                props.get("node.nick", ""),
                props.get("node.description", ""),
            ]
            if args.node_name in names:
                exact.append((node_id, entry))
        matches = exact

    if not matches:
        print(f"Error: No node found matching '{args.node_name}'", file=sys.stderr)
        print("\nAvailable nodes:", file=sys.stderr)
        for entry in dump:
            if entry.get("type") == "PipeWire:Interface:Node":
                props = entry.get("info", {}).get("props", {})
                name = props.get("node.name", "")
                nick = props.get("node.nick", "")
                desc = props.get("node.description", "")
                label = name or nick or desc
                extra = []
                if nick and nick != name:
                    extra.append(f"nick: {nick}")
                if desc and desc != name:
                    extra.append(f"desc: {desc}")
                extras = f"  ({', '.join(extra)})" if extra else ""
                print(f"  [{entry['id']}] {label}{extras}", file=sys.stderr)
        sys.exit(1)

    if len(matches) > 1:
        print(
            f"Warning: Multiple nodes match '{args.node_name}'. "
            f"Using the first match. Use --exact or a more specific name.",
            file=sys.stderr,
        )
        for node_id, entry in matches:
            props = entry.get("info", {}).get("props", {})
            print(
                f"  [{node_id}] {props.get('node.name', '')} "
                f"/ {props.get('node.description', '')}",
                file=sys.stderr,
            )

    node_id, node_entry = matches[0]
    node_props = node_entry.get("info", {}).get("props", {})
    node_display_name = (
        node_props.get("node.name")
        or node_props.get("node.nick")
        or node_props.get("node.description")
        or str(node_id)
    )

    print(f"Found node: [{node_id}] {node_display_name}", file=sys.stderr)

    # Get parameter info
    current_params = get_node_params(dump, node_id)
    prop_types = get_prop_types(dump, node_id)

    if args.list:
        print_node_params(node_id, current_params, prop_types)
        sys.exit(0)

    param_name = args.param_name

    # Validate param name
    known_params = set(current_params.keys()) | set(prop_types.keys())
    if known_params and param_name not in known_params:
        print(
            f"Error: Parameter '{param_name}' not found for node '{node_display_name}'.",
            file=sys.stderr,
        )
        print_node_params(node_id, current_params, prop_types)
        sys.exit(1)
    elif not known_params:
        print(
            f"Warning: Could not enumerate parameters for node '{node_display_name}'. "
            f"Proceeding anyway.",
            file=sys.stderr,
        )

    # Coerce and validate value
    prop_info_entry = prop_types.get(param_name)
    value = coerce_value(args.value, prop_info_entry)

    is_valid, error_msg = validate_value(value, prop_info_entry, param_name)
    if not is_valid:
        print(f"Error: {error_msg}", file=sys.stderr)
        sys.exit(1)

    # Show what we're about to do
    if param_name in current_params:
        current = current_params[param_name].get("current", "?")
        print(f"Setting '{param_name}': {current} -> {value}", file=sys.stderr)
    else:
        print(f"Setting '{param_name}' = {value}", file=sys.stderr)

    # Apply
    is_param = prop_info_entry.get("is_param", False)
    success = set_param(node_id, param_name, value, is_param=is_param)
    sys.exit(0 if success else 1)


if __name__ == "__main__":
    main()
